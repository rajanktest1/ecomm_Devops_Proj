# ──────────────────────────────────────────────────────────────────────────────
#  ShopEase — .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Environment & secrets ──────────────────────────────────────────────────────
.env
.env.*
!.env.example          # allow a safe example template to be committed
*.pem
*.key
*.cert
*.crt
secrets/

# ── Node.js ────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn/
.pnp.*
package-lock.json    # uncomment if you prefer to track lockfiles (recommended)

# ── Build output ───────────────────────────────────────────────────────────────
frontend/dist/
frontend/.vite/
backend/build/

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite files contain real user + cart data — never commit them
data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── Terraform ─────────────────────────────────────────────────────────────────
# State files contain plain-text secrets (passwords, keys, connection strings)
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.*
terraform/terraform.tfstate.backup
# Variable override files may contain real credentials
terraform/*.tfvars
terraform/*.tfvars.json
# Exception: commit the example tfvars template
!terraform/terraform.tfvars.example

# ── Docker ─────────────────────────────────────────────────────────────────────
.docker/

# ── Kubernetes ─────────────────────────────────────────────────────────────────
# Never commit kubeconfig or generated secret manifests
kubeconfig
*.kubeconfig
k8s/**/secret*.yaml
k8s/**/*-secret.yaml

# ── Logs ───────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── OS noise ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── IDE / editor ───────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json   # allow sharing recommended extensions
!.vscode/settings.json     # allow sharing workspace settings
.idea/
*.suo
*.user
*.swp
*.swo
*~

# ── Test & coverage ────────────────────────────────────────────────────────────
coverage/
.nyc_output/
