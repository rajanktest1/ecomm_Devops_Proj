# ──────────────────────────────────────────────────────────────────────────────
#  ShopEase — .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Environment & secrets ──────────────────────────────────────────────────────
.env
.env.*
!.env.example          # allow the safe example template to be committed
*.pem
*.key
*.cert
*.crt
secrets/

# ── Node.js ────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn/
.pnp.*
# package-lock.json is intentionally tracked — it pins exact dependency versions

# ── Build output ───────────────────────────────────────────────────────────────
frontend/dist/
frontend/.vite/
backend/build/

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite files contain real user + cart data — never commit them
data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── Terraform ─────────────────────────────────────────────────────────────────
# .terraform/ — downloaded provider binaries (large, machine-specific)
.terraform/
terraform/.terraform/

# .terraform.lock.hcl — SHOULD be committed (pins provider versions like package-lock.json)
# It is NOT ignored here intentionally.

# State files contain plain-text resource IDs, secrets, and connection strings
terraform.tfstate
terraform.tfstate.*
terraform.tfstate.backup
terraform/**/*.tfstate
terraform/**/*.tfstate.*
terraform/**/*.tfstate.backup

# crash logs produced by terraform
crash.log
crash.*.log

# Variable override files may contain real credentials
*.tfvars
*.tfvars.json
# Exception: commit the documented example template
!terraform/terraform.tfvars.example

# ── Docker ─────────────────────────────────────────────────────────────────────
.docker/

# ── Kubernetes ─────────────────────────────────────────────────────────────────
# Never commit kubeconfig — it contains cluster credentials
kubeconfig
*.kubeconfig
k8s/**/secret*.yaml
k8s/**/*-secret.yaml

# ── Logs ───────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── OS noise ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── IDE / editor ───────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json   # allow sharing recommended extensions
!.vscode/settings.json     # allow sharing workspace settings
.idea/
*.suo
*.user
*.swp
*.swo
*~

# ── Test & coverage ────────────────────────────────────────────────────────────
coverage/
.nyc_output/
